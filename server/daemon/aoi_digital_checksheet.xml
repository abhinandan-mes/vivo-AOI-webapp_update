<service>
	<id>aoi_digital_checksheet.exe</id>
	<name>AOI_Digital_Checksheet</name>
	<description>Vivo AOI Digital Checksheet App Service</description>
	<executable>C:\Program Files\nodejs\node.exe</executable>
	<argument>--harmony</argument>
	<argument>D:\AOi_check_sheet\server\node_modules\node-windows\lib\wrapper.js</argument>
	<argument>--file</argument>
	<argument>d:\AOi_check_sheet\server\server.js</argument>
	<argument>--scriptoptions=</argument>
	<argument>--log</argument>
	<argument>AOI_Digital_Checksheet wrapper</argument>
	<argument>--grow</argument>
	<argument>0.25</argument>
	<argument>--wait</argument>
	<argument>1</argument>
	<argument>--maxrestarts</argument>
	<argument>3</argument>
	<argument>--abortonerror</argument>
	<argument>n</argument>
	<argument>--stopparentfirst</argument>
	<argument>undefined</argument>
	<logmode>rotate</logmode>
	<stoptimeout>30sec</stoptimeout>
	<env name="NODE_ENV" value="production"/>
	<serviceaccount>
		<domain>INVXW47684</domain>
		<user>LocalSystem</user>
		<password></password>
	</serviceaccount>
	<workingdirectory>D:\AOi_check_sheet\server</workingdirectory>
</service>